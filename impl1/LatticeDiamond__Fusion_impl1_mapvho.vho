-- entity i2c_sdaB
  library IEEE, vital2000, MACHXO2;
  use IEEE.STD_LOGIC_1164.all;
  use vital2000.vital_timing.all;
  use MACHXO2.COMPONENTS.ALL;

  entity i2c_sdaB is
    -- miscellaneous vital GENERICs
    GENERIC (
      TimingChecksOn	: boolean := TRUE;
      XOn           	: boolean := FALSE;
      MsgOn         	: boolean := TRUE;
      InstancePath  	: string := "i2c_sdaB";

      tipd_PADDT  	: VitalDelayType01 := (0 ns, 0 ns);
      tipd_PADDO  	: VitalDelayType01 := (0 ns, 0 ns);
      tipd_i2csda  	: VitalDelayType01 := (0 ns, 0 ns);
      tpd_PADDT_i2csda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        ;
      tpd_PADDO_i2csda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        ;
      tpd_i2csda_PADDI	 : VitalDelayType01 := (0 ns, 0 ns);
      tperiod_i2csda 	: VitalDelayType := 0 ns;
      tpw_i2csda_posedge	: VitalDelayType := 0 ns;
      tpw_i2csda_negedge	: VitalDelayType := 0 ns;

        tpd_i2csda_i2csda	 : VitalDelayType01Z := (0 ns, 0 ns, 0 ns , 0 ns, 0 ns, 0 ns)
        );

    port (PADDI: out Std_logic; PADDT: in Std_logic; PADDO: in Std_logic; 
          i2csda: inout Std_logic);

    ATTRIBUTE Vital_Level0 OF i2c_sdaB : ENTITY IS TRUE;

  end i2c_sdaB;

  architecture Structure of i2c_sdaB is
    ATTRIBUTE Vital_Level0 OF Structure : ARCHITECTURE IS TRUE;

    signal PADDI_out 	: std_logic := 'X';
    signal PADDT_ipd 	: std_logic := 'X';
    signal PADDO_ipd 	: std_logic := 'X';
    signal i2csda_ipd 	: std_logic := 'X';
    signal i2csda_out 	: std_logic := 'Z';

    component xo2iobuf
      port (I: in Std_logic; T: in Std_logic; Z: out Std_logic; 
            PAD: out Std_logic; PADI: in Std_logic);
    end component;
  begin
    i2c_sda_pad: xo2iobuf
      port map (I=>PADDO_ipd, T=>PADDT_ipd, Z=>PADDI_out, PAD=>i2csda_out, 
                PADI=>i2csda_ipd);

    --  INPUT PATH DELAYs
    WireDelay : BLOCK
    BEGIN
      VitalWireDelay(PADDT_ipd, PADDT, tipd_PADDT);
      VitalWireDelay(PADDO_ipd, PADDO, tipd_PADDO);
      VitalWireDelay(i2csda_ipd, i2csda, tipd_i2csda);
    END BLOCK;

    VitalBehavior : PROCESS (PADDI_out, PADDT_ipd, PADDO_ipd, i2csda_ipd, 
      i2csda_out)
    VARIABLE PADDI_zd         	: std_logic := 'X';
    VARIABLE PADDI_GlitchData 	: VitalGlitchDataType;
    VARIABLE i2csda_zd         	: std_logic := 'X';
    VARIABLE i2csda_GlitchData 	: VitalGlitchDataType;

    VARIABLE tviol_i2csda_i2csda          	: x01 := '0';
    VARIABLE periodcheckinfo_i2csda	: VitalPeriodDataType;

    BEGIN

    IF (TimingChecksOn) THEN
      VitalPeriodPulseCheck (
        TestSignal => i2csda_ipd,
        TestSignalName => "i2csda",
        Period => tperiod_i2csda,
        PulseWidthHigh => tpw_i2csda_posedge,
        PulseWidthLow => tpw_i2csda_negedge,
        PeriodData => periodcheckinfo_i2csda,
        Violation => tviol_i2csda_i2csda,
        MsgOn => MsgOn, XOn => XOn,
        HeaderMsg => InstancePath,
        CheckEnabled => TRUE,
        MsgSeverity => warning);

    END IF;

    PADDI_zd 	:= PADDI_out;
    i2csda_zd 	:= i2csda_out;

    VitalPathDelay01 (
      OutSignal => PADDI, OutSignalName => "PADDI", OutTemp => PADDI_zd,
      Paths      => (0 => (InputChangeTime => i2csda_ipd'last_event,
                           PathDelay => tpd_i2csda_PADDI,
                           PathCondition => TRUE)),
      GlitchData => PADDI_GlitchData,
      Mode       => vitaltransport, XOn => XOn, MsgOn => MsgOn);
    VitalPathDelay01Z (
      OutSignal => i2csda, OutSignalName => "i2csda", OutTemp => i2csda_zd,
      Paths      => (0 => (InputChangeTime => PADDT_ipd'last_event,
                           PathDelay => tpd_PADDT_i2csda,
                           PathCondition => TRUE),
                     1 => (InputChangeTime => PADDO_ipd'last_event,
                           PathDelay => tpd_PADDO_i2csda,
                           PathCondition => TRUE)),
      GlitchData => i2csda_GlitchData,
      Mode       => vitaltransport, XOn => XOn, MsgOn => MsgOn);

    END PROCESS;

  end Structure;

