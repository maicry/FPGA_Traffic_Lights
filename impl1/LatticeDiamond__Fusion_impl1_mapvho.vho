  entity u_detecter_u1_SLICE_171 is
    -- miscellaneous vital GENERICs
    GENERIC (
      TimingChecksOn	: boolean := TRUE;
      XOn           	: boolean := FALSE;
      MsgOn         	: boolean := TRUE;
      InstancePath  	: string := "u_detecter_u1_SLICE_171";

      tipd_D0  	: VitalDelayType01 := (0 ns, 0 ns);
